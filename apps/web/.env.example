NEXT_PUBLIC_SUPABASE_URL="https://<YOUR_PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<YOUR_SUPABASE_ANON_KEY>"

# For applying `supabase/schema.sql` via `npm run db:migrate` (never expose to browser)
SUPABASE_DB_URL="postgresql://postgres:<YOUR_DB_PASSWORD>@db.<YOUR_PROJECT_REF>.supabase.co:5432/postgres"

# Dev-only (DO NOT enable in prod)
NEXT_PUBLIC_ENABLE_ADMIN_BYPASS="false"
